# Virtual environment
.venv/

# Python cache
__pycache__/
*.pyc

# Platform tools — keep adb binaries, ignore the rest
platform-tools/*
!platform-tools/adb.exe
!platform-tools/AdbWinApi.dll
!platform-tools/AdbWinUsbApi.dll

# macOS
.DS_Store

# Debug output
debug/

# Training data (generated at runtime, uploaded via bug reports)
training_data/

# Logs and stats
logs/
stats/
9bot.log

# License key
.license_key

# User settings
settings.json

# Reports (generated locally, sent directly to testers)
reports/

# Bug report inbox (drop ZIPs here for /analyze)
inbox/*.zip

# Runtime data (player name cache, etc.)
data/

# Protocol R&D artifacts (captures, logs — source files are tracked)
protocol/capture*.json
protocol/live_capture.log
protocol/live_registry.json

# Claude Code — track commands and analysis, ignore transient state
.claude/*
!.claude/commands/
!.claude/analysis/
!.claude/settings.json
